{
  "version": 2,
  "functions": {
    "api/main.py": {
      "runtime": "vercel-python@0.1.1"
    }
  },
  "builds": [
    {
      "src": "saoo/**/*.php",
      "use": "vercel-php@0.6.0"
    },
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/main.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/saoo/$1"
    }
  ]
}
